ook-menu nav ul ul li a:hover{color:var(--accent)}.book-menu nav>ul>li>span,.book-menu nav>ul>li>label{display:flex;user-select:none;color:var(--text-muted)}.book-menu nav>ul>li>label:hover{background-color:var(--accent-light)}.book-toc{font-family:dm sans,sans-serif;font-size:.8rem;border-left:1px solid var(--border-light);padding-left:1.2rem}.book-toc nav>ul{list-style:none;padding:0}.book-toc nav>ul li{margin-bottom:.3rem}.book-toc nav>ul li a{color:var(--text-muted);text-decoration:none;border:none;transition:color .15s;line-height:1.5}.book-toc nav>ul li a:hover{color:var(--accent)}.book-toc nav>ul li.active>a{color:var(--accent);font-weight:500}.book-toc nav>ul ul{padding-left:.8rem;margin-top:.2rem}.book-toc nav>ul ul li a{font-size:.77rem;color:var(--border-medium)}.book-header{background-color:var(--bg-main);border-bottom:1px solid var(--border-light);font-family:dm sans,sans-serif}.book-header label{color:var(--text-secondary)}.book-search input{background-color:var(--bg-code);border:1px solid var(--border-medium);border-radius:4px;color:var(--text-primary);font-family:dm sans,sans-serif;font-size:.875rem;padding:.4rem .7rem;transition:border-color .15s}.book-search input:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 2px var(--accent-light)}.book-search input::placeholder{color:var(--text-muted)}.book-hint{border-radius:4px;padding:1rem 1.2rem;margin:1.6rem 0;border-left:3px solid;font-family:dm sans,sans-serif;font-size:.925rem}.book-hint p:last-child{margin-bottom:0}.book-hint.info{background-color:#eaf0fb;border-left-color:#3b6ccf;color:#1a2f6a}.book-hint.warning{background-color:#fef6e4;border-left-color:#d48a0c;color:#5c3a00}.book-hint.danger{background-color:#fdecea;border-left-color:#c0392b;color:#5c1010}.book-footer{font-family:dm sans,sans-serif;margin-top:3rem;padding-top:1.5rem;border-top:1px solid var(--border-light);color:var(--text-muted);font-size:.875rem}.book-nav{display:flex;justify-content:space-between;margin-top:2rem;padding-top:1.2rem;border-top:1px solid var(--border-light)}.book-nav a{font-family:dm sans,sans-serif;font-size:.875rem;font-weight:500;color:var(--text-secondary);text-decoration:none;border:none;transition:color .15s}.book-nav a:hover{color:var(--accent)}@media(prefers-color-scheme:dark){:root{--bg-main:#1a1917;--bg-code:#252320;--bg-blockquote:#22201d;--text-primary:#e8e4de;--text-secondary:#a09a92;--text-muted:#666058;--text-sidebar:#c8c2ba;--accent:#d4824a;--accent-light:#2a1f14;--accent-subtle:#3a2818;--border-light:#2e2c28;--border-medium:#403c38}.markdown pre{background-color:#111009;border-color:#2a2820}.book-hint.info{background-color:#131c2e;color:#8aaaf0}.book-hint.warning{background-color:#201900;color:#d4a84a}.book-hint.danger{background-color:#1e0a0a;color:#e07070}}@media(max-width:768px){body{font-size:16px}.markdown h1{font-size:1.7rem}.markdown h2{font-size:1.25rem}.markdown h3{font-size:1.05rem}}:root{--body-background:white;--body-background-tint:none;--body-font-color:black;--color-link:#0055bb;--color-visited-link:#5500bb;--icon-filter:none;--gray-100:#f8f9fa;--gray-200:#e9ecef;--gray-500:#adb5bd;--color-accent-default:#64748b;--color-accent-default-tint:rgba(100, 116, 139, 0.1);--color-accent-note:#4486dd;--color-accent-note-tint:rgba(68, 134, 221, 0.1);--color-accent-tip:#3bad3b;--color-accent-tip-tint:rgba(59, 173, 59, 0.1);--color-accent-important:#8144dd;--color-accent-important-tint:rgba(129, 68, 221, 0.1);--color-accent-warning:#f59e42;--color-accent-warning-tint:rgba(245, 158, 66, 0.1);--color-accent-caution:#d84747;--color-accent-caution-tint:rgba(216, 71, 71, 0.1);--color-accent-info:#4486dd;--color-accent-info-tint:rgba(68, 134, 221, 0.1);--color-accent-success:#3bad3b;--color-accent-success-tint:rgba(59, 173, 59, 0.1);--color-accent-danger:#d84747;--color-accent-danger-tint:rgba(216, 71, 71, 0.1)}